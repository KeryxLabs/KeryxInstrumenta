# STTP home-server compose profile
# Used by src/sttp/docker-compose.yml

# Gateway image tag
STTP_GATEWAY_IMAGE_TAG=2.0.0-beta.0

# Gateway runtime
STTP_GATEWAY_BACKEND=surreal
STTP_GATEWAY_REMOTE=true
STTP_GATEWAY_HTTP_PORT=8080
STTP_GATEWAY_GRPC_PORT=8081

# CORS
# For quick LAN dry-runs, '*' is convenient.
# For tighter policy, replace with comma-separated origins.
STTP_GATEWAY_CORS_ENABLED=true
STTP_GATEWAY_CORS_ALLOWED_ORIGINS=*

# SurrealDB remote connection
STTP_SURREAL_REMOTE_ENDPOINT=ws://10.12.0.11:1908/rpc
STTP_SURREAL_NAMESPACE=keryx
STTP_SURREAL_DATABASE=sttp_mcp_test
STTP_SURREAL_USER=root
STTP_SURREAL_PASSWORD=root

# Optional features (off by default for stable dry-run)
STTP_GATEWAY_EMBEDDINGS_ENABLED=false
STTP_GATEWAY_AVEC_SCORING_ENABLED=false
