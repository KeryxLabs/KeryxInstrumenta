	private static FutureSelfPreview BuildFutureSelfPreview(PsychLayer psych, DeltaStory delta)
	{
		var title = psych.OrbClass switch
		{
			"orb-alert" => "If this pace continues",
			"orb-focused" => "If this focus continues",
			"orb-connective" => "If this openness continues",
			_ => "If this balance continues"
		};

		var likelyPath = psych.OrbClass switch
		{
			"orb-alert" => "You may feel mentally crowded and decision quality could drop by later sessions.",
			"orb-focused" => "You will likely produce clear output quickly, with strong follow-through.",
			"orb-connective" => "You may unlock progress through people and fresh perspectives.",
			_ => "You may sustain steady progress with lower emotional volatility."
		};

		var shiftPath = psych.OrbClass == "orb-alert"
			? "Small shift: remove one obligation and protect 20 minutes for recovery before the next push."
			: delta.Headline.Contains("dropped", StringComparison.OrdinalIgnoreCase)
				? "Small shift: restore the dropped axis with one tiny, concrete action in the next hour."
				: "Small shift: lock a single next step now so this state turns into compounding momentum.";

		return new FutureSelfPreview(title, likelyPath, shiftPath);
	}

	private static InnerDialogue BuildInnerDialogue(PsychLayer psych, DeltaStory delta)
	{
		var analyst = psych.OrbClass switch
		{
			"orb-alert" => "Signal says load is high; reduce friction before adding complexity.",
			"orb-focused" => "Signal says execution window is open; prioritize one high-impact task.",
			"orb-connective" => "Signal says collaboration leverage is available; involve someone early.",
			_ => "Signal says system is stable; keep cadence and avoid unnecessary context switching."
		};

		var human = psych.OrbClass switch
		{
			"orb-alert" => "I want relief and permission to make this simpler.",
			"orb-focused" => "I want to finish something meaningful and feel proud of it.",
			"orb-connective" => "I want support and momentum that does not feel lonely.",
			_ => "I want progress that feels calm, not chaotic."
		};

		var synthesis = delta.Headline.Contains("stable", StringComparison.OrdinalIgnoreCase)
			? "Synthesis: keep this state by choosing one visible win and ending on purpose."
			: "Synthesis: honor both signal and emotion by taking one action that is useful and humane.";

		return new InnerDialogue(analyst, human, synthesis);
	}

	private static LifeContextTags BuildLifeContextTags(PsychLayer psych)
	{
		var curiosity = psych.Axes[0].Value;
		var discipline = psych.Axes[1].Value;
		var socialEnergy = psych.Axes[2].Value;
		var flexibility = psych.Axes[3].Value;
		var stressLoad = psych.Axes[4].Value;

		var tags = new List<LifeContextTag>();

		if (stressLoad >= 0.68f)
			tags.Add(new LifeContextTag("Recovery Mode", 0f));

		if (discipline >= 0.70f && stressLoad < 0.55f)
			tags.Add(new LifeContextTag("Deep Focus", 220f));
		else if (discipline >= 0.65f && stressLoad >= 0.55f)
			tags.Add(new LifeContextTag("Work Sprint", 270f));

		if (curiosity >= 0.68f && flexibility >= 0.58f)
			tags.Add(new LifeContextTag("Creative Flow", 38f));
		else if (curiosity >= 0.62f && discipline < 0.60f)
			tags.Add(new LifeContextTag("Exploration Phase", 160f));

		if (socialEnergy >= 0.66f)
			tags.Add(new LifeContextTag("Social Push", 145f));

		if (flexibility >= 0.62f && stressLoad < 0.48f && discipline >= 0.54f && !tags.Any(t => t.Label == "Deep Focus"))
			tags.Add(new LifeContextTag("Planning Mode", 200f));

		if (tags.Count == 0)
			tags.Add(new LifeContextTag("Steady State", 215f));

		string moodNote;
		if (tags.Count == 1)
		{
			moodNote = tags[0].Label switch
			{
				"Recovery Mode" => "Load is high — protect your energy and simplify the next move.",
				"Deep Focus" => "A clear execution window is open right now.",
				"Work Sprint" => "Pushing through with pressure behind you.",
				"Creative Flow" => "Curiosity and flexibility are converging — follow it.",
				"Exploration Phase" => "Curiosity is leading. Good moment to follow without forcing structure.",
				"Social Push" => "Connection energy is high. Good time to involve someone.",
				"Planning Mode" => "Adaptive structure available — map before you move.",
				_ => "Steady momentum — the state is sustainably balanced."
			};
		}
		else if (tags.Count == 2)
		{
			moodNote = $"Blending {tags[0].Label.ToLowerInvariant()} with {tags[1].Label.ToLowerInvariant()}.";
		}
		else
		{
			moodNote = $"Complex state: {string.Join(", ", tags.Take(3).Select(t => t.Label.ToLowerInvariant()))}.";
		}

		return new LifeContextTags(tags, moodNote);
	}

	private static BlindSpotLens BuildBlindSpotLens(PsychLayer psych)
	{
		var curiosity = psych.Axes[0].Value;
		var discipline = psych.Axes[1].Value;
		var socialEnergy = psych.Axes[2].Value;
		var flexibility = psych.Axes[3].Value;
		var stressLoad = psych.Axes[4].Value;

		var opportunities = new[]
		{
			("curiosity",     1f - curiosity),
			("discipline",    1f - discipline),
			("social energy", 1f - socialEnergy),
			("flexibility",   1f - flexibility),
			("stress load",   stressLoad)
		};

		var strongest = opportunities.OrderByDescending(o => o.Item2).First();

		if (strongest.Item2 < 0.18f)
			return new BlindSpotLens(
				"Coherence Balance",
				"Your state is unusually aligned — which makes it easy to drift without noticing.",
				"Nudge: name one priority so this balance turns into compounding momentum, not comfortable inertia.");

		return strongest.Item1 switch
		{
			"curiosity" => new BlindSpotLens(
				"Curiosity Gap",
				"You may be solving the known problem instead of questioning whether it is the right one.",
				"Nudge: ask one question you have not asked yet about this situation."),
			"discipline" => new BlindSpotLens(
				"Commitment Gap",
				"You may be circling without committing. One locked action beats ten open loops.",
				"Nudge: name one specific deliverable with a finish line you can hold yourself to."),
			"social energy" => new BlindSpotLens(
				"Connection Gap",
				"You may be going it alone when a conversation would accelerate the work.",
				"Nudge: share one update or ask one question with someone who would benefit or help."),
			"flexibility" => new BlindSpotLens(
				"Flexibility Gap",
				"You may be attached to a path that has already shifted beneath you.",
				"Nudge: identify one assumption you have been protecting and test it quickly."),
			_ => new BlindSpotLens(
				"Stress Buildup",
				"Carrying more than you are registering. The signal is quiet, but the weight is real.",
				"Nudge: before adding more, finish or drop one thing from your current active list.")
		};
	}

	private static string GetContextTagStyle(LifeContextTag tag)
