	private static string FormatRaw(string? raw)
		=> string.IsNullOrWhiteSpace(raw) ? "(empty)" : raw.Replace("\r\n", "\n").Trim();

	private async Task CopyRawAsync(string? raw)
	{
		if (string.IsNullOrWhiteSpace(raw)) return;
		await JS.InvokeVoidAsync("navigator.clipboard.writeText", FormatRaw(raw));
		rawCopied = true;
		StateHasChanged();
		await Task.Delay(1800);
		rawCopied = false;
		StateHasChanged();
	}

	private static RenderFragment RenderAvec(string title, AvecState? avec) => builder =>
	{
		builder.OpenElement(0, "div");
		builder.AddAttribute(1, "class", "avec-card");

		builder.OpenElement(2, "p");
		builder.AddAttribute(3, "class", "avec-title");
		builder.AddContent(4, title);
		builder.CloseElement();

		if (avec is null)
		{
			builder.OpenElement(5, "p");
			builder.AddAttribute(6, "class", "muted inline-meta");
			builder.AddContent(7, "Not available");
			builder.CloseElement();
		}
		else
		{
			builder.OpenElement(8, "div");
			builder.AddAttribute(9, "class", "avec-rows");
			AddAvecRow(builder, 10, "Steadiness", avec.Stability);
			AddAvecRow(builder, 20, "Resistance", avec.Friction);
			AddAvecRow(builder, 30, "Clarity", avec.Logic);
			AddAvecRow(builder, 40, "Independence", avec.Autonomy);
			AddAvecRow(builder, 50, "Overall Score", avec.Psi);
			builder.CloseElement();
		}

		builder.CloseElement();
	};

	private static void AddAvecRow(RenderTreeBuilder builder, int sequence, string label, float value)
	{
		builder.OpenElement(sequence, "div");
		builder.AddAttribute(sequence + 1, "class", "avec-row");
		builder.OpenElement(sequence + 2, "span");
		builder.AddContent(sequence + 3, label);
		builder.CloseElement();
		builder.OpenElement(sequence + 4, "strong");
		builder.AddContent(sequence + 5, value.ToString("0.000"));
		builder.CloseElement();
		builder.CloseElement();
	}

	private static PsychLayer BuildPsychLayer(SttpNodeDto node)
	{
		var state = ResolveState(node);
		var curiosity = Clamp01(state.Logic * 0.58f + state.Autonomy * 0.42f);
		var discipline = Clamp01(state.Stability * 0.64f + (1f - state.Friction) * 0.36f);
		var socialEnergy = Clamp01(state.Autonomy * 0.56f + (1f - state.Friction) * 0.44f);
		var flexibility = Clamp01((1f - state.Stability) * 0.34f + state.Logic * 0.36f + state.Autonomy * 0.30f);
		var stressLoad = Clamp01(state.Friction * 0.74f + (1f - state.Stability) * 0.26f);

		var axes = new List<PsychAxis>
		{
			new("Curiosity", curiosity),
			new("Discipline", discipline),
			new("Social Energy", socialEnergy),
			new("Flexibility", flexibility),
			new("Stress Load", stressLoad)
		};

		var coherence = (curiosity + discipline + socialEnergy + flexibility + (1f - stressLoad)) / 5f;
		var leadAxis = HighestAxis(axes);
		var quietAxis = LowestAxis(axes);
		var archetype = ResolveArchetype(curiosity, discipline, socialEnergy, flexibility, stressLoad);
		var reflection = $"Right now this session leans on {leadAxis.ToLowerInvariant()} while {quietAxis.ToLowerInvariant()} stays quieter.";
		var nextNudge = stressLoad >= 0.68f
			? "Nudge: lower load first, then lock one small move you can finish quickly."
			: coherence >= 0.66f
				? "Nudge: convert this stable shape into one concrete next action before context shifts."
				: "Nudge: lift the quietest axis with a tiny, low-friction step.";
		var scopeNote = "Session-state snapshot only. This is momentum context, not identity.";

		var orbClass = stressLoad >= 0.68f
			? "orb-alert"
			: discipline >= 0.7f && curiosity >= 0.62f
				? "orb-focused"
				: socialEnergy >= 0.65f && flexibility >= 0.58f
					? "orb-connective"
					: "orb-balanced";

		var hue = Math.Clamp(18f + curiosity * 54f + socialEnergy * 22f - stressLoad * 16f, 12f, 122f);
		var energy = Clamp01((curiosity + socialEnergy + flexibility) / 3f);
		var pulse = Math.Clamp(0.35f + stressLoad * 0.9f, 0.35f, 1.2f);
		var orbCaption = $"Coherence {coherence:0.00} · {archetype}";

		return new PsychLayer(
			axes,
			archetype,
			reflection,
			nextNudge,
			scopeNote,
			orbClass,
			hue,
			energy,
			pulse,
			BuildRadarDataPoints(axes),
			coherence,
			orbCaption);
	}

	private static AvecState ResolveState(SttpNodeDto node)
	{
		if (node.CompressionAvec is not null)
			return node.CompressionAvec;

		return new AvecState(
			(node.UserAvec.Stability + node.ModelAvec.Stability) / 2f,
			(node.UserAvec.Friction + node.ModelAvec.Friction) / 2f,
			(node.UserAvec.Logic + node.ModelAvec.Logic) / 2f,
			(node.UserAvec.Autonomy + node.ModelAvec.Autonomy) / 2f,
			(node.UserAvec.Psi + node.ModelAvec.Psi) / 2f);
	}

	private static string ResolveArchetype(float curiosity, float discipline, float socialEnergy, float flexibility, float stressLoad)
	{
		if (stressLoad >= 0.74f)
			return "Pressure Navigator";
		if (discipline >= 0.72f && curiosity >= 0.65f)
			return "Precision Explorer";
		if (socialEnergy >= 0.68f && flexibility >= 0.6f)
			return "Bridge Builder";
		if (curiosity >= 0.72f && flexibility >= 0.62f)
			return "Pattern Diver";
		return "Steady Integrator";
	}

	private static string HighestAxis(IReadOnlyList<PsychAxis> axes)
		=> axes.OrderByDescending(a => a.Value).First().Name;

	private static string LowestAxis(IReadOnlyList<PsychAxis> axes)
		=> axes.OrderBy(a => a.Value).First().Name;

	private static string BuildRadarDataPoints(IReadOnlyList<PsychAxis> axes)
	{
		var points = new List<string>(axes.Count);
		for (var i = 0; i < axes.Count; i++)
		{
			var point = PolarPoint(i, axes[i].Value, 76f);
			points.Add($"{point.X.ToString("0.##", CultureInfo.InvariantCulture)},{point.Y.ToString("0.##", CultureInfo.InvariantCulture)}");
		}
		return string.Join(" ", points);
	}

	private static string BuildRadarRingPoints(float radius)
	{
		var points = new List<string>(5);
		for (var i = 0; i < 5; i++)
		{
			var point = PolarPoint(i, 1f, radius);
			points.Add($"{point.X.ToString("0.##", CultureInfo.InvariantCulture)},{point.Y.ToString("0.##", CultureInfo.InvariantCulture)}");
		}
		return string.Join(" ", points);
	}

