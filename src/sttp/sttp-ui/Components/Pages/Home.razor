	private sealed record FutureSelfPreview(string Title, string LikelyPath, string ShiftPath);
	private sealed record InnerDialogue(string Analyst, string Human, string Synthesis);
	private sealed record LifeContextTag(string Label, float Hue);
	private sealed record LifeContextTags(IReadOnlyList<LifeContextTag> Tags, string MoodNote);
	private sealed record BlindSpotLens(string Label, string Observation, string Nudge);
	private sealed record GentleCelebration(bool Show, string Glyph, string Title, string Body);
	private sealed record JournalExportEntry(string[] Lines, string FullText);
	private sealed record RecommendedAction(string Action, string Why);

	private sealed class SessionGroup(string sessionId, List<SttpNodeDto> nodes)
	{
		public string SessionId { get; } = sessionId;
		public List<SttpNodeDto> Nodes { get; } = nodes;
		public SttpNodeDto LatestNode => Nodes[0];
		public DateTime LastModified => LatestNode.Timestamp;
	}

	private async Task RunSafeAsync(Func<Task> work)
	{
		isWorking = true;
		try
		{
			await work();
		}
		catch (Exception ex)
		{
			healthText = $"error: {ex.Message}";
			healthClass = "status-bad";
		}
		finally
		{
			isWorking = false;
		}
	}

	public async ValueTask DisposeAsync()
	{
		_dotNetRef?.Dispose();
		try
		{
			if (_swipeModule is not null)
				await _swipeModule.DisposeAsync();
			if (_graphModule is not null)
			{
				await _graphModule.InvokeVoidAsync("destroySessionGraph", "sttp-graph");
				await _graphModule.DisposeAsync();
			}
		}
		catch (JSDisconnectedException) { }
	}
}
