{
  "name": "acc-vscode",
  "displayName": "ACC - Adaptive Codec Context",
  "version": "0.3.0",
  "publisher": "KeryxLabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/KeryxLabs/KeryxInstrumenta"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "acc.downloadServer",
        "title": "ACC: Download Server Binary"
      },
      {
        "command": "acc.buildGraph",
        "title": "ACC: Build Dependency Graph"
      },
      {
        "command": "acc.search",
        "title": "ACC: Search Nodes"
      },
      {
        "command": "acc.showStats",
        "title": "ACC: Show Project Stats"
      },
      {
        "command": "acc.showHighFriction",
        "title": "ACC: Show High-Friction Nodes"
      },
      {
        "command": "acc.showUnstable",
        "title": "ACC: Show Unstable Nodes"
      }
    ],
    "configuration": {
      "title": "ACC",
      "properties": {
        "acc.serverPath": {
          "type": "string",
          "description": "Custom path to ACC server binary (leave empty for auto-download)"
        },
        "acc.rpcPort": {
          "type": "number",
          "description": "The location for querying via JSON rpc.",
          "default": 9339
        },
        "acc.lspPort": {
          "type": "number",
          "description": "The TCP port where the LSP will be communicating to the engine.",
          "default": 9340
        },
        "acc.database.remote": {
          "type": "boolean",
          "description": "Enable the ability to sink your indexing and metrics to a remote SurrealDb instance.",
          "default": false
        },
        "acc.database.remoteEndpoint": {
          "type": "string",
          "description": "The surrealdb remote location. Only used when set up for remote.",
          "default": "ws://localhost:8000/rpc"
        }, 
        "acc.telemetry.use":{
          "type": "boolean",
          "description": "Enable the usage of telemetry. This allows for observability as the code indexing happens. Gathers same metrics as database store. See Grafana Dashboards examples for more info.",
          "default": false
        },
        "acc.telemetry.endpoint":{
          "type":"string",
          "description": "The endpoint for collecting OTEL telemetry. Usually an otel collector or a sink",
          "default":"localhost:4317"
        }
        ,
        "acc.avecWeights.override": {
          "type": "boolean",
          "description": "When true, pass configured AvecWeights flags to the ACC engine (overrides engine defaults)",
          "default": false
        }
        ,
        "acc.avecWeights.stability.churnWeight": {
          "type": "number",
          "default": 0.4
        },
        "acc.avecWeights.stability.contributorWeight": {
          "type": "number",
          "default": 0.3
        },
        "acc.avecWeights.stability.testWeight": {
          "type": "number",
          "default": 0.3
        },
        "acc.avecWeights.stability.churnNormalize": {
          "type": "number",
          "default": 10
        },
        "acc.avecWeights.stability.testLineCoverageNormalize": {
          "type": "number",
          "default": 100.0
        },
        "acc.avecWeights.stability.testLineCoverageWeight": {
          "type": "number",
          "default": 0.5
        },
        "acc.avecWeights.stability.testBranchCoverageNormalize": {
          "type": "number",
          "default": 100.0
        },
        "acc.avecWeights.stability.testBranchCoverageWeight": {
          "type": "number",
          "default": 0.5
        },
        "acc.avecWeights.stability.testBaseBias": {
          "type": "number",
          "default": 0.5
        },
        "acc.avecWeights.stability.contributorCap": {
          "type": "number",
          "default": 5
        },
        "acc.avecWeights.logic.complexityWeight": {
          "type": "number",
          "default": 0.7
        },
        "acc.avecWeights.logic.parameterWeight": {
          "type": "number",
          "default": 0.3
        },
        "acc.avecWeights.logic.locDivisor": {
          "type": "number",
          "default": 10
        },
        "acc.avecWeights.logic.parameterCap": {
          "type": "number",
          "default": 5
        },
        "acc.avecWeights.friction.centralityWeight": {
          "type": "number",
          "default": 0.4
        },
        "acc.avecWeights.friction.dependencyWeight": {
          "type": "number",
          "default": 0.6
        },
        "acc.avecWeights.friction.churnWeight": {
          "type": "number",
          "default": 0.7
        },
        "acc.avecWeights.friction.collaborationNormalize": {
          "type": "number",
          "default": 0.3
        },
        "acc.avecWeights.friction.structuralFrictionWeight": {
          "type": "number",
          "default": 0.4
        },
        "acc.avecWeights.friction.processFrictionWeight": {
          "type": "number",
          "default": 0.3
        },
        "acc.avecWeights.friction.cognitiveFrictionWeight": {
          "type": "number",
          "default": 0.3
        },
        "acc.avecWeights.friction.cyclomaticComplexityWeight": {
          "type": "number",
          "default": 20.0
        },
        "acc.avecWeights.friction.gitContributorsNormalize": {
          "type": "number",
          "default": 10.0
        },
        "acc.avecWeights.friction.gitTotalCommitsNormalize": {
          "type": "number",
          "default": 50.0
        },
        "acc.avecWeights.friction.incomingCap": {
          "type": "number",
          "default": 10
        },
        "acc.avecWeights.autonomy.fileNumberBlastRadius": {
          "type": "number",
          "default": 30
        },
        "acc.avecWeights.autonomy.dependencyRatio": {
          "type": "number",
          "default": 0.8
        },
        "acc.avecWeights.autonomy.absoluteCount": {
          "type": "number",
          "default": 0.2
        }
      }
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "tar": "^7.5.11"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  }
}
